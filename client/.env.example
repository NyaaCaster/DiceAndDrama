# NyaaChat-MCP streamable-HTTP endpoint. Used by nginx envsubst at container
# start to inject the Bearer token so the API key never reaches the frontend.
MCP_HOST=http://h.hony-wen.com
MCP_PORT=3094
MCP_API_KEY=

# Container time zone. Used by the nginx runtime so access-log timestamps
# render in local time. The SPA itself runs in the browser and uses the
# user's system zone, so this value does not reach the frontend bundle.
TZ=Asia/Shanghai
